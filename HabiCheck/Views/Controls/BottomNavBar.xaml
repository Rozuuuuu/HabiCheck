<UserControl x:Class="HabiCheck.Views.Controls.BottomNavBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="600">
    <UserControl.Resources>
        <!-- 💡 DEVELOPER NOTE: Button Style defined inside Resources to customize buttons with custom rounded borders and hovers. -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource CreamBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <!-- 💡 DEVELOPER NOTE: When hovered, background transitions to lighter sage green -->
                    <Setter Property="Background" Value="{StaticResource SageGreenBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource DeepSageBrush}" Padding="10,8" CornerRadius="16,16,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🏠 Dashboard" Style="{StaticResource NavButton}" Click="Dashboard_Click"/>
            <Button Grid.Column="1" Content="📷 Scan Fabric" Style="{StaticResource NavButton}" Click="Scanner_Click"/>
            <Button Grid.Column="2" Content="📜 Scan History" Style="{StaticResource NavButton}" Click="History_Click"/>
        </Grid>
    </Border>
</UserControl>
