<UserControl x:Class="HabiCheck.Views.Controls.FabricChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:HabiCheck.Converters"
             xmlns:models="clr-namespace:HabiCheck.Models"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="350">
    
    <UserControl.Resources>
        <!-- Register value converters for XAML binding transformations -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:ChatBubbleColorConverter x:Key="BubbleColor"/>
        <converters:ChatTextColorConverter x:Key="TextColor"/>
        <converters:ChatAlignmentConverter x:Key="Alignment"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>

        <!-- Design styles for the control -->
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TerracottaBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CreamBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="Foreground" Value="Gray"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource SageGreenBrush}" BorderThickness="1" CornerRadius="12" Background="#FAF8F5" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Messages Area -->
                <RowDefinition Height="Auto"/> <!-- Loading / Error -->
                <RowDefinition Height="Auto"/> <!-- Input Controls -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <Border Grid.Row="0" Background="{StaticResource DeepSageBrush}" Margin="0,0,0,10" Padding="10,8" CornerRadius="8">
                <Grid>
                    <TextBlock Text="💬 Ask Antigravity AI" Foreground="{StaticResource CreamBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="{StaticResource CreamBrush}" BorderThickness="0" Cursor="Hand" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- 2. Scrollable Messages Area -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                <!-- ItemsControl displays lists in WPF. Safe and simple alternative to ListBox -->
                <ItemsControl ItemsSource="{Binding ChatHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:FabricChatMessage}">
                            <!-- 💡 DEVELOPER NOTE: ChatAlignmentConverter pushes user messages to the right and assistant to the left -->
                            <Border CornerRadius="10" Padding="10" Margin="4,4,4,6" MaxWidth="260"
                                    HorizontalAlignment="{Binding Role, Converter={StaticResource Alignment}}"
                                    Background="{Binding Role, Converter={StaticResource BubbleColor}}">
                                <!-- 💡 DEVELOPER NOTE: ChatTextColorConverter selects readable text color depending on bubble bg -->
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12" LineHeight="16"
                                           Foreground="{Binding Role, Converter={StaticResource TextColor}}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 3. Loading Indicator & Errors -->
            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                <!-- AI thinking message -->
                <TextBlock Text="Antigravity is writing..." Foreground="{StaticResource SageGreenBrush}" FontStyle="Italic" FontSize="11" Margin="5,0,0,0"
                           Visibility="{Binding IsAiLoading, Converter={StaticResource BoolToVisibility}}"/>
                
                <!-- AI error message -->
                <TextBlock Text="{Binding AiError}" Foreground="{StaticResource TerracottaBrush}" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="11" Margin="5,0,0,0"
                           Visibility="{Binding AiError, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <!-- 4. Input Row -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input Text Box -->
                <TextBox Grid.Column="0" Text="{Binding NewChatMessage, UpdateSourceTrigger=PropertyChanged}" 
                         VerticalAlignment="Center" Padding="8,6" Margin="0,0,8,0" BorderBrush="#D1CFCB" 
                         BorderThickness="1" Background="{StaticResource InputBgBrush}" KeyDown="TextBox_KeyDown"
                         IsEnabled="{Binding IsAiLoading, Converter={StaticResource InverseBool}}"/>

                <!-- Send Button -->
                <Button Grid.Column="1" Content="Send" Width="60" Style="{StaticResource SendButton}"
                        Command="{Binding SendChatMessageCommand}"
                        IsEnabled="{Binding IsAiLoading, Converter={StaticResource InverseBool}}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
