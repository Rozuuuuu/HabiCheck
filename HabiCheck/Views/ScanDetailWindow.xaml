<Window x:Class="HabiCheck.Views.ScanDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:HabiCheck.Views.Controls"
        xmlns:converters="clr-namespace:HabiCheck.Converters"
        mc:Ignorable="d"
        Title="HabiCheck — Scan Details" 
        Height="750"
        MinHeight="580" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CreamBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>

        <!-- Premium styles for detail display -->
        <Style x:Key="DetailCard" TargetType="Border">
            <Setter Property="Background" Value="#FAF8F5"/>
            <Setter Property="BorderBrush" Value="#EAE7E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="MetricProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#E5E0D8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
        </Style>
    </Window.Resources>

    <!-- The window width grows naturally as the user resizes. The chat column
         collapses to 0 when IsChatOpen=False and opens to 340 when True. -->

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Column 0: Main detail content  - stretches with window -->
            <ColumnDefinition Width="*" MinWidth="380"/>
            <!-- Column 1: AI Chat Drawer - width 0 when closed, 340 when open -->
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChatOpen}" Value="True">
                                <Setter Property="Width" Value="340"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0: MAIN SCAN DETAILS -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Scrollable Detail Info -->
                <RowDefinition Height="Auto"/> <!-- Bottom Actions / Back -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <Border Grid.Row="0" Background="{StaticResource DeepSageBrush}" Padding="15">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <!-- Back button -->
                        <Button Content="🠔" Background="Transparent" Foreground="{StaticResource CreamBrush}" BorderThickness="0" Cursor="Hand" FontSize="18" FontWeight="Bold" Margin="0,0,15,0"
                                Command="{Binding NavigateBackCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBlock Text="📷 Scan History Details" FontSize="18" FontWeight="Black" Foreground="{StaticResource CreamBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Antigravity AI Chat toggle button -->
                    <Button Content="💬 Chat AI" HorizontalAlignment="Right" Padding="12,6" Background="{StaticResource TerracottaBrush}" Foreground="{StaticResource CreamBrush}" BorderThickness="0" Cursor="Hand" FontWeight="Bold"
                            Command="{Binding ToggleChatCommand}"/>
                </Grid>
            </Border>

            <!-- 2. Main Scrollable Panel -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,16,16,0">
                <StackPanel>
                    <!-- Loading Indicator -->
                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" Margin="0,30,0,0">
                        <TextBlock Text="Loading details..." FontSize="16" Foreground="{StaticResource DeepSageBrush}" HorizontalAlignment="Center"/>
                        <ProgressBar Height="4" IsIndeterminate="True" Width="200" Margin="0,10,0,0" Foreground="{StaticResource TerracottaBrush}"/>
                    </StackPanel>

                    <!-- Loaded View -->
                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                        <!-- Top Image Banner -->
                        <Border Background="#FAF8F5" BorderBrush="#EAE7E2" BorderThickness="1.5" CornerRadius="12" Padding="6" Height="220" Margin="0,0,0,16" ClipToBounds="True">
                            <Image Source="{Binding LocalImagePath}" Stretch="Uniform"/>
                        </Border>

                        <!-- Fabric Overview Card -->
                        <Border Style="{StaticResource DetailCard}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{Binding Fabric.Name}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DeepSageBrush}"/>
                                    <!-- Grade Badge -->
                                    <Border HorizontalAlignment="Right" Background="{StaticResource TerracottaBrush}" CornerRadius="15" Padding="10,4">
                                        <TextBlock Text="{Binding Fabric.Grade}" FontSize="12" FontWeight="ExtraBold" Foreground="{StaticResource CreamBrush}"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding Fabric.FiberType}" FontSize="13" Foreground="#66625D" Margin="0,2,0,15"/>

                                <!-- Meters -->
                                <TextBlock Text="Breathability" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SageGreenBrush}"/>
                                <Grid>
                                    <ProgressBar Value="{Binding Fabric.Breathability}" Style="{StaticResource MetricProgress}" Foreground="{StaticResource DeepSageBrush}"/>
                                    <TextBlock Text="{Binding Fabric.Breathability, StringFormat='{}{0}%'}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource DeepSageBrush}" HorizontalAlignment="Right" Margin="0,-16,0,0"/>
                                </Grid>

                                <TextBlock Text="Sustainability" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SageGreenBrush}"/>
                                <Grid>
                                    <ProgressBar Value="{Binding Fabric.Sustainability}" Style="{StaticResource MetricProgress}" Foreground="{StaticResource SageGreenBrush}"/>
                                    <TextBlock Text="{Binding Fabric.Sustainability, StringFormat='{}{0}%'}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SageGreenBrush}" HorizontalAlignment="Right" Margin="0,-16,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Personal message -->
                        <Border Style="{StaticResource DetailCard}">
                            <StackPanel>
                                <TextBlock Text="📝 Wearer Guide" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DeepSageBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Fabric.PersonalMessage}" FontSize="13" Foreground="#44413E" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,10"/>
                                
                                <Border Background="#FFF1E8" BorderBrush="{StaticResource TerracottaBrush}" BorderThickness="1,0,0,0" Padding="12,10" CornerRadius="0,6,6,0"
                                        Visibility="{Binding Fabric.ClimateAlert, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="⚠️ Cebu Climate Alert" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TerracottaBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Fabric.ClimateAlert}" FontSize="12" Foreground="#4D3B31" TextWrapping="Wrap" LineHeight="16"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 3. Bottom Actions -->
            <Border Grid.Row="2" Background="{StaticResource DeepSageBrush}" Padding="15,10">
                <Grid>
                    <TextBlock Text="{Binding Scan.ScannedAt, StringFormat='Scanned on: {0}'}" Foreground="{StaticResource CreamBrush}" VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                    
                    <!-- Back Button -->
                    <Button Content="Back to History" HorizontalAlignment="Right" Padding="15,8" Background="Transparent" Foreground="{StaticResource CreamBrush}" BorderBrush="{StaticResource CreamBrush}" BorderThickness="1.5" Cursor="Hand"
                            Command="{Binding NavigateBackCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- COLUMN 1: AI CHAT DRAWER -->
        <Border Grid.Column="1" Background="{StaticResource InputBgBrush}" Padding="8,10,12,10"
                Visibility="{Binding IsChatOpen, Converter={StaticResource BoolToVisibility}}">
            <!-- Embed our custom chat drawer control -->
            <controls:FabricChatControl DataContext="{Binding}"/>
        </Border>
    </Grid>
</Window>
